{{!--
  One parameterized template serving both framework tabs.

  The search bar and list structure reuse dnd5e's own custom elements rather
  than imitating them (live-session finding, 2026-07-21): <item-list-controls>
  builds its native search UI, and it resolves its target list via
  [data-item-list="<for>"] from inside a <dnd5e-inventory> ancestor, with the
  list as a SIBLING of div.middle (nesting the list inside .middle stretches
  the bar in the flex row). Rows carry data-item-name for the element's name
  filter, plus data-item-id / data-entry-id / data-uuid per dnd5e convention.

  The active class on the root section MUST be rendered from context:
  ApplicationV2's changeTab no-ops when its state already matches, so a
  re-render that drops the class leaves the open tab blank.
--}}
<section class="tab veyl-tab {{framework}} {{#if tab.active}}active{{/if}}" data-group="primary" data-tab="{{framework}}">
  {{#if held}}
  <section class="top">
    <div class="spellcasting card veyl-card">
      <div class="header">
        <h3>{{craftName}}</h3>
      </div>
      <div class="info">
        <div class="ability">
          <span class="label">{{localize "VEYL.Ability"}}</span>
          <span class="value">{{abilityAbbr}}</span>
        </div>
        <div class="attack">
          <span class="label">{{localize "VEYL.Attack"}}</span>
          <span class="value">{{attack}}</span>
        </div>
        <div class="save">
          <span class="label">{{localize "VEYL.SaveDC"}}</span>
          <span class="value">{{dc}}</span>
        </div>
        {{#if mp}}
        <div class="prepared">
          <span class="label">{{localize "VEYL.Mana"}}</span>
          <span class="value">{{mp.value}}/{{mp.max}}</span>
        </div>
        {{else}}
        <div class="prepared">
          <span class="label">{{localize "VEYL.ReadyHand"}}</span>
          <span class="value">{{hand}}</span>
        </div>
        {{/if}}
      </div>
    </div>
  </section>

  <dnd5e-inventory class="inventory-element">
    <div class="middle">
      <item-list-controls for="{{framework}}" collection="items" label="{{localize 'VEYL.SearchAbilities'}}" keep-empty=""></item-list-controls>
    </div>
    <section class="items-list spells-list veyl-list" data-item-list="{{framework}}">
      {{#each sections}}
      <div class="items-section card" data-discipline="{{this.id}}">
        <div class="items-header header">
          <h3 class="item-name">{{localize this.label}}</h3>
          <div class="item-header veyl-col">{{localize "VEYL.Cost"}}</div>
          <div class="item-header veyl-col">{{localize "VEYL.Time"}}</div>
          <div class="item-header veyl-col"></div>
        </div>
        <ol class="item-list unlist">
          {{#each this.items}}
          <li class="item veyl-collapsible {{#unless this.expanded}}veyl-collapsed{{/unless}}" data-item-id="{{this.id}}" data-entry-id="{{this.id}}" data-item-name="{{this.name}}" data-uuid="{{this.uuid}}">
            <div class="item-row draggable">
              {{!-- dnd5e-inventory binds clicks only to .item-action[data-action] and
                    [data-context-menu]. In Edit mode the name keeps dnd5e's edit
                    action (opens the sheet); in Play mode it carries our own
                    toggle marker instead, which dnd5e ignores and expand.mjs
                    handles by delegation. --}}
              <div class="item-name item-action rollable" {{#if @root.editMode}}data-action="edit"{{else}}data-veyl-toggle=""{{/if}}>
                <img class="item-image gold-icon" src="{{this.img}}" alt="">
                <div class="name name-stacked">
                  <span class="title">{{this.name}}</span>
                  <span class="subtitle">{{this.subtitle}}</span>
                </div>
              </div>
              <div class="item-detail veyl-col">{{this.cost}}</div>
              <div class="item-detail veyl-col"><span class="condensed">{{this.time}}</span></div>
              <div class="item-detail item-controls always-visible veyl-col">
                <button type="button" class="unbutton item-control always-interactive" data-veyl-post="" data-tooltip aria-label="{{localize 'VEYL.PostToChat'}}">
                  <i class="fa-solid fa-comment-alt"></i>
                </button>
                <button type="button" class="unbutton config-button item-control always-interactive" data-context-menu="" aria-label="{{localize 'DND5E.AdditionalControls'}}">
                  <i class="fa-solid fa-ellipsis-vertical"></i>
                </button>
              </div>
            </div>
            {{#with this.summary}}
            <div class="veyl-summary">
              <div class="veyl-summary-meta">
                {{#if this.activationLabel}}<span class="veyl-meta">{{this.activationLabel}}</span>{{/if}}
                {{#if this.trigger}}<span class="veyl-meta">{{localize "VEYL.Trigger"}}: {{this.trigger}}</span>{{/if}}
                {{#if this.duration}}<span class="veyl-meta">{{this.duration}}</span>{{/if}}
                {{#if this.concentration}}<span class="veyl-meta veyl-conc">{{localize "VEYL.Field.concentration"}}</span>{{/if}}
              </div>
              {{#if this.rich}}<div class="veyl-summary-text">{{{this.rich}}}</div>{{/if}}
              {{#if this.ladder}}
              <div class="veyl-ladder" aria-label="{{localize 'VEYL.Summary.Ladder'}}">
                {{#each this.ladder}}
                <span class="veyl-ladder-step {{#if this.threshold}}veyl-threshold{{/if}}">
                  <span class="step">{{this.step}}</span>
                  <span class="cost">{{this.cost}}</span>
                </span>
                {{/each}}
                <span class="veyl-ladder-unit">{{this.costUnit}}</span>
              </div>
              {{#if this.perStep}}
              <p class="veyl-line"><strong>{{localize "VEYL.Field.perStep"}}:</strong> {{this.perStep}}</p>
              {{/if}}
              {{/if}}
              {{#each this.evolutions}}
              <div class="veyl-line veyl-evolution">
                <strong>{{localize "VEYL.ThresholdStep" step=this.step}}:</strong>
                <div class="veyl-inline-rich">{{{this.enriched}}}</div>
              </div>
              {{/each}}
              {{#if this.fixed}}<p class="veyl-line veyl-fixed">{{this.fixed}}</p>{{/if}}
              {{#if this.amplifyRich}}
              <div class="veyl-line veyl-amplify">
                <strong>{{localize "VEYL.Field.amplify"}}:</strong>
                <div class="veyl-inline-rich">{{{this.amplifyRich}}}</div>
              </div>
              {{/if}}
              {{#each this.deepenings}}
              <div class="veyl-line veyl-deepening">
                <strong>{{localize "VEYL.DeepeningLevel" level=this.level}}:</strong>
                <div class="veyl-inline-rich">{{{this.enriched}}}</div>
              </div>
              {{/each}}
            </div>
            {{/with}}
          </li>
          {{else}}
          <li class="item veyl-empty">
            <div class="item-row">
              <div class="item-name">
                <div class="name name-stacked"><span class="subtitle">{{localize "VEYL.EmptySection"}}</span></div>
              </div>
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/each}}
    </section>
  </dnd5e-inventory>
  {{/if}}
</section>
